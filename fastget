}

gdrive_confirm_url_from_html() {
  python3 -c '
from html.parser import HTMLParser
from urllib.parse import urlencode, urljoin
import sys

class Parser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.active = False
        self.action = ""
        self.params = []
        self.link = ""

    def handle_starttag(self, tag, attrs):
        data = dict(attrs)
        if tag == "form":
            action = data.get("action", "")
            form_id = data.get("id", "")
            if form_id == "download-form" or "drive.usercontent.google.com" in action or "/uc" in action or "/download" in action:
                self.active = True
                self.action = action
                self.params = []
        elif tag == "input" and self.active:
            name = data.get("name")
            if name:
                self.params.append((name, data.get("value", "")))
        elif tag == "a" and data.get("id") == "uc-download-link":
            href = data.get("href", "")
            if href:
                self.link = href

    def handle_endtag(self, tag):
        if tag == "form" and self.active:
            self.active = False

parser = Parser()
parser.feed(sys.stdin.read())

if parser.action and parser.params:
    action = urljoin("https://drive.google.com", parser.action)
    sep = "&" if "?" in action else "?"
    print(action + sep + urlencode(parser.params))
elif parser.link:
    print(urljoin("https://drive.google.com", parser.link))
else:
    raise SystemExit(1)
'
}

gdrive_cookie_header_from_jar() {
  local cookie_file="$1"
  awk '
    BEGIN { sep = "" }
    /^#HttpOnly_/ { sub(/^#HttpOnly_/, "", $1) }
    /^#/ { next }
    NF >= 7 {
      printf "%s%s=%s", sep, $6, $7
      sep = "; "
    }
  ' "$cookie_file"
}

join_cookie_headers() {
  local first="$1"
  local second="$2"

  if [ -n "$first" ] && [ -n "$second" ]; then
    printf '%s; %s' "$first" "$second"
  else
    printf '%s%s' "$first" "$second"
  fi
}

gdrive_user_cookie_header() {
  if [ -n "${FASTGET_GDRIVE_COOKIE:-}" ]; then
    printf '%s' "$FASTGET_GDRIVE_COOKIE"
  elif [ -n "${FASTGET_GDRIVE_COOKIE_FILE:-}" ]; then
    [ -r "$FASTGET_GDRIVE_COOKIE_FILE" ] || die "FASTGET_GDRIVE_COOKIE_FILE is not readable: ${FASTGET_GDRIVE_COOKIE_FILE}"
    gdrive_cookie_header_from_jar "$FASTGET_GDRIVE_COOKIE_FILE"
  fi
}

gdrive_cookie_cache_enabled() {
  case "$(lower "$FASTGET_GDRIVE_COOKIE_CACHE_DISABLE")" in
    1|true|yes|on) return 1 ;;
    *) [ -n "$FASTGET_GDRIVE_COOKIE_CACHE" ] ;;
  esac
}

save_gdrive_cookie_cache() {
  local cookie="$1"
  local cache_dir

  gdrive_cookie_cache_enabled || return 0
  cache_dir="${FASTGET_GDRIVE_COOKIE_CACHE%/*}"
  [ -n "$cache_dir" ] && [ "$cache_dir" != "$FASTGET_GDRIVE_COOKIE_CACHE" ] || return 0

  mkdir -p "$cache_dir"
  (
    umask 077
    printf '%s\n' "$cookie" >"$FASTGET_GDRIVE_COOKIE_CACHE"
  )
  chmod 600 "$FASTGET_GDRIVE_COOKIE_CACHE" 2>/dev/null || true
  note "Google Drive: saved Cookie value to ${FASTGET_GDRIVE_COOKIE_CACHE}"
}

load_gdrive_cookie_cache() {
  [ -z "${FASTGET_GDRIVE_COOKIE:-}" ] || return 0
  [ -z "${FASTGET_GDRIVE_COOKIE_FILE:-}" ] || return 0
  gdrive_cookie_cache_enabled || return 0
  [ -r "$FASTGET_GDRIVE_COOKIE_CACHE" ] || return 0

  IFS= read -r FASTGET_GDRIVE_COOKIE <"$FASTGET_GDRIVE_COOKIE_CACHE" || true
  [ -n "$FASTGET_GDRIVE_COOKIE" ] || return 0
  note "Google Drive: using cached Cookie value from ${FASTGET_GDRIVE_COOKIE_CACHE}"
}

inputs_include_gdrive() {
  local input
  for input in "${INPUTS[@]}"; do
    if is_gdrive "$input"; then
      return 0
    fi
  done
  return 1
}

gdrive_cookie_from_curl_stdin() {
  python3 -c '
import shlex
import sys

try:
    args = shlex.split(sys.stdin.read())
except ValueError as exc:
    raise SystemExit(f"could not parse clipboard cURL command: {exc}")


def header_cookie(value):
    if value.lower().startswith("cookie:"):
        return value.split(":", 1)[1].strip()
    return ""


for i, arg in enumerate(args):
    value = ""
    if arg in ("-b", "--cookie") and i + 1 < len(args):
        value = args[i + 1].strip()
    elif arg.startswith("--cookie="):
        value = arg.split("=", 1)[1].strip()
    elif arg.startswith("-b") and len(arg) > 2:
        value = arg[2:].strip()

    if value:
        print(value)
        raise SystemExit

    if arg in ("-H", "--header") and i + 1 < len(args):
        value = header_cookie(args[i + 1])
    elif arg.startswith("--header="):
        value = header_cookie(arg.split("=", 1)[1])
    elif arg.startswith("-H") and len(arg) > 2:
        value = header_cookie(arg[2:])

    if value:
        print(value)
        raise SystemExit

raise SystemExit("no -b/--cookie or Cookie: header found in clipboard cURL command")
'
}

