}

append_download() {
  local i="${#DL_URLS[@]}"
  DL_URLS[i]="$1"
  DL_NAMES[i]="$2"
  DL_COOKIES[i]="$3"
  DL_ORIGINS[i]="$4"
  DL_PROVIDERS[i]="$5"
}

resolve_pixeldrain() {
  local url="$1"
  local path file_id direct_url

  path="$(url_path "$url")"
  case "$path" in
    /api/file/*)
      append_download "$url" "" "" "$url" "pixeldrain"
      note "Pixeldrain: URL is already a direct API file link"
      return 0
      ;;
    /u/*)
      file_id="${path#/u/}"
      file_id="${file_id%%/*}"
      ;;
    *)
      die "Could not extract Pixeldrain file ID from: ${url}"
      ;;
  esac

  [ -n "$file_id" ] || die "Could not extract Pixeldrain file ID from: ${url}"
  direct_url="https://pixeldrain.com/api/file/${file_id}"
  append_download "$direct_url" "" "" "$url" "pixeldrain"
  note "Pixeldrain: converted file ${file_id} to direct download URL"
}

gdrive_direct_url() {
  local file_id="$1"
  printf 'https://drive.usercontent.google.com/download?id=%s&export=download&confirm=t' "$file_id"
}

gdrive_filename_from_headers() {
  local headers="$1"
  local cd name

  cd="$(printf '%s\n' "$headers" | tr -d '\r' | grep -i '^content-disposition:' | tail -n 1 || true)"
  [ -n "$cd" ] || return 1

  name="$(printf '%s' "$cd" | sed -n "s/.*filename\\*=UTF-8''\\([^;]*\\).*/\\1/p" | tail -n 1)"
  if [ -z "$name" ]; then
    name="$(printf '%s' "$cd" | sed -n 's/.*filename="\([^"]*\)".*/\1/p' | tail -n 1)"
  fi
  if [ -z "$name" ]; then
    name="$(printf '%s' "$cd" | sed -n 's/.*filename=\([^;]*\).*/\1/p' | tail -n 1)"
  fi

  name="${name%\"}"
  name="${name#\"}"
  [ -n "$name" ] || return 1
  url_decode_if_possible "$name"
}

gdrive_content_type_from_headers() {
  local headers="$1"
  printf '%s\n' "$headers" | tr -d '\r' | awk '
    BEGIN { value = "" }
    tolower($1) == "content-type:" {
      $1 = ""
      sub(/^[[:space:]]+/, "")
      value = tolower($0)
    }
    END { print value }
  '
}

gdrive_status_from_headers() {
  local headers="$1"
  printf '%s\n' "$headers" | tr -d '\r' | awk '
    /^HTTP\// { code = $2 }
    END { print code }
  '
}

gdrive_curl_head() {
  local url="$1"

  if [ -n "${FASTGET_GDRIVE_COOKIE_FILE:-}" ]; then
    [ -r "$FASTGET_GDRIVE_COOKIE_FILE" ] || die "FASTGET_GDRIVE_COOKIE_FILE is not readable: ${FASTGET_GDRIVE_COOKIE_FILE}"
    curl -fsSLI -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -b "$FASTGET_GDRIVE_COOKIE_FILE" "$url"
  elif [ -n "${FASTGET_GDRIVE_COOKIE:-}" ]; then
    curl -fsSLI -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -H "Cookie: ${FASTGET_GDRIVE_COOKIE}" "$url"
  else
    curl -fsSLI -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$url"
  fi
}

gdrive_curl_get() {
  local url="$1"

  if [ -n "${FASTGET_GDRIVE_COOKIE_FILE:-}" ]; then
    [ -r "$FASTGET_GDRIVE_COOKIE_FILE" ] || die "FASTGET_GDRIVE_COOKIE_FILE is not readable: ${FASTGET_GDRIVE_COOKIE_FILE}"
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -b "$FASTGET_GDRIVE_COOKIE_FILE" "$url"
  elif [ -n "${FASTGET_GDRIVE_COOKIE:-}" ]; then
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -H "Cookie: ${FASTGET_GDRIVE_COOKIE}" "$url"
  else
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$url"
  fi
}

gdrive_curl_get_with_jar() {
  local url="$1"
  local cookie_file="$2"

  if [ -n "${FASTGET_GDRIVE_COOKIE_FILE:-}" ]; then
    [ -r "$FASTGET_GDRIVE_COOKIE_FILE" ] || die "FASTGET_GDRIVE_COOKIE_FILE is not readable: ${FASTGET_GDRIVE_COOKIE_FILE}"
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -b "$FASTGET_GDRIVE_COOKIE_FILE" -c "$cookie_file" "$url"
  elif [ -n "${FASTGET_GDRIVE_COOKIE:-}" ]; then
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -H "Cookie: ${FASTGET_GDRIVE_COOKIE}" -c "$cookie_file" "$url"
  else
    curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" -b "$cookie_file" -c "$cookie_file" "$url"
  fi
}

gdrive_interstitial_error_from_html() {
  python3 -c '
import html
import re
import sys

page = sys.stdin.read()
text = html.unescape(re.sub(r"<[^>]+>", " ", page))
text = " ".join(text.split())
lower = text.lower()

if "quota exceeded" in lower or "too many users have viewed or downloaded" in lower:
