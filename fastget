load_gdrive_cookie_from_chrome() {
  local chrome_profile cookie

  need_tool python3 "Install it with: brew install python"
  need_tool security "This feature requires macOS (the 'security' keychain command is not available)."
  need_tool openssl "macOS normally includes openssl."

  chrome_profile="${FASTGET_GDRIVE_CHROME_PROFILE:-}"

  cookie="$(python3 - "$chrome_profile" <<'PY'
import hashlib
import os
import shutil
import sqlite3
import subprocess
import sys
import tempfile


def get_keychain_password():
    result = subprocess.run(
        ["security", "find-generic-password", "-w",
         "-s", "Chrome Safe Storage", "-a", "Chrome"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        raise SystemExit(
            "Could not read Chrome Safe Storage from Keychain. "
            "Make sure Google Chrome is installed and you have granted access."
        )
    return result.stdout.strip()


def derive_key(password):
    return hashlib.pbkdf2_hmac("sha1", password.encode("utf-8"), b"saltysalt", 1003, 16)


def is_safe_cookie_value(text):
    """Cookie values must be printable ASCII; reject binary garbage."""
    return bool(text) and all(0x20 <= ord(c) <= 0x7E for c in text)


def decrypt_cookie_value(encrypted_value, key):
    if not encrypted_value:
        return None
    if not encrypted_value.startswith(b"v1"):
        # Unencrypted - plain text stored in encrypted_value column
        try:
            text = encrypted_value.decode("utf-8")
            return text if is_safe_cookie_value(text) else None
        except UnicodeDecodeError:
            return None
    # Chrome macOS cookie format (Chrome 127+):
    #   v10 (3 bytes) + 16-byte header + 16-byte per-cookie IV + AES-128-CBC ciphertext
    # Earlier versions used a fixed space IV with no header, but all modern cookies
    # embed the IV at offset 16 within the encrypted blob.
    raw = encrypted_value[3:]  # strip v10/v11 prefix
    if len(raw) < 33:
        return None
    iv = raw[16:32]
    ciphertext = raw[32:]
    if len(ciphertext) % 16 != 0:
        return None
    result = subprocess.run(
        ["openssl", "enc", "-d", "-aes-128-cbc",
         "-K", key.hex(), "-iv", iv.hex(), "-nosalt"],
        input=ciphertext,
        capture_output=True,
    )
    if result.returncode != 0:
        return None
    try:
        text = result.stdout.decode("utf-8")
    except UnicodeDecodeError:
        return None
    return text if is_safe_cookie_value(text) else None


def find_cookies_db(profile_hint):
    home = os.path.expanduser("~")
    base = os.path.join(home, "Library", "Application Support", "Google", "Chrome")
    if profile_hint:
        candidate = os.path.join(base, profile_hint, "Cookies")
        if os.path.exists(candidate):
            return candidate
        raise SystemExit(f"Chrome cookies DB not found at: {candidate}")
    candidates = []
    if os.path.isdir(base):
        for entry in os.listdir(base):
            p = os.path.join(base, entry, "Cookies")
            if os.path.exists(p):
                candidates.append((entry, p))
    candidates.sort(key=lambda x: (x[0] != "Default", x[0]))
    if not candidates:
        raise SystemExit(
            "Chrome cookies database not found. Is Google Chrome installed?"
        )
    return candidates[0][1]


def main():
    profile_hint = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] else ""
    password = get_keychain_password()
    key = derive_key(password)
    cookies_path = find_cookies_db(profile_hint)

    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(suffix=".db", delete=False) as f:
            tmp_path = f.name
        shutil.copy2(cookies_path, tmp_path)

        conn = sqlite3.connect(f"file:{tmp_path}?mode=ro", uri=True)
        cursor = conn.execute(
            "SELECT name, encrypted_value, value FROM cookies "
            "WHERE host_key LIKE '%.google.com' OR host_key = 'google.com' "
            "ORDER BY host_key, name"
        )

        parts = []
        for name, encrypted_value, plain_value in cursor:
            if encrypted_value:
                value = decrypt_cookie_value(encrypted_value, key)
            else:
                value = plain_value or ""
            if value and name and is_safe_cookie_value(value):
                parts.append(f"{name}={value}")

        conn.close()

        if not parts:
            raise SystemExit(
                "No Google cookies found in Chrome. "
                "Make sure you are signed in to Google in Chrome."
            )

        print("; ".join(parts))
    finally:
        if tmp_path:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass


main()
PY
)"
  [ -n "$cookie" ] || die "Could not extract Google Drive cookies from Chrome"
  FASTGET_GDRIVE_COOKIE="$cookie"
  note "Google Drive: loaded Cookie from Chrome"
  save_gdrive_cookie_cache "$cookie"
}

gdrive_verify_not_html() {
  local url="$1"
  local cookie_header="${2-}"
  local file_id="${3-}"
  local sample message

  # Google can return an HTML error page (quota, access denied) with a 200 status
  # and a binary-looking Content-Type on HEAD — meaning the HEAD check passes but
  # aria2c then saves an HTML page as the output file.  Fetch the first 1 KB via
  # a range GET to detect this before handing the URL to aria2c.
  if [ -n "$cookie_header" ]; then
    sample="$(curl -sSL --range 0-1023 --max-time 15 \
      -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" \
      -H "Cookie: ${cookie_header}" \
      "$url" 2>/dev/null || true)"
  else
    sample="$(curl -sSL --range 0-1023 --max-time 15 \
      -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" \
      "$url" 2>/dev/null || true)"
  fi

  [ -n "$sample" ] || return 0

  case "$sample" in
    '<!DOCTYPE '*|'<!doctype '*|'<html>'*|'<html '*|'<HTML'*)
      if command -v python3 >/dev/null 2>&1; then
        if message="$(printf '%s' "$sample" | gdrive_interstitial_error_from_html 2>/dev/null)"; then
          die "$message"
        fi
      fi
      die "Google Drive returned an HTML page instead of the file${file_id:+ (ID ${file_id})}. The link may be quota-limited, private, or unavailable."
      ;;
  esac
}

append_gdrive_file() {
  local origin="$1"
  local file_id="$2"
  local fallback_filename="${3-}"
  local direct_url headers filename content_type status_code cookie_file page message confirm_url cookie_header user_cookie_header jar_cookie_header

  direct_url="$(gdrive_direct_url "$file_id")"
  headers="$(gdrive_curl_head "$direct_url" 2>/dev/null || true)"
  filename="$(gdrive_filename_from_headers "$headers" || true)"

  if [ -z "$filename" ]; then
    filename="$fallback_filename"
  fi

  content_type="$(gdrive_content_type_from_headers "$headers")"
  status_code="$(gdrive_status_from_headers "$headers")"
  cookie_header="$(gdrive_user_cookie_header || true)"
  case "$content_type" in
    text/html*)
      need_tool python3 "Install it with: brew install python"
      cookie_file="$(mktemp "${TMPDIR:-/tmp}/fastget-gdrive-cookies.XXXXXX")" || die "Could not create temporary Google Drive cookie jar"
      page="$(gdrive_curl_get_with_jar "$direct_url" "$cookie_file" 2>/dev/null || true)"

      if message="$(printf '%s' "$page" | gdrive_interstitial_error_from_html 2>/dev/null)"; then
        rm -f "$cookie_file"
        die "$message"
      fi

      confirm_url="$(printf '%s' "$page" | gdrive_confirm_url_from_html 2>/dev/null || true)"
      if [ -z "$confirm_url" ]; then
        rm -f "$cookie_file"
        die "Google Drive returned an HTML page instead of a file for ID ${file_id}. The link may require login, be quota-limited, or be blocked."
      fi

      direct_url="$confirm_url"
      user_cookie_header="$(gdrive_user_cookie_header || true)"
      jar_cookie_header="$(gdrive_cookie_header_from_jar "$cookie_file" || true)"
      cookie_header="$(join_cookie_headers "$user_cookie_header" "$jar_cookie_header")"
      headers="$(gdrive_curl_head "$direct_url" 2>/dev/null || true)"
      rm -f "$cookie_file"

      if [ -z "$filename" ]; then
        filename="$(gdrive_filename_from_headers "$headers" || true)"
      fi
      status_code="$(gdrive_status_from_headers "$headers")"
      ;;
  esac

  if is_uint "$status_code" && [ "$status_code" -ge 400 ]; then
    die "Google Drive download endpoint returned HTTP ${status_code} for file ID ${file_id}. The file may be unavailable, private, quota-limited, or blocked."
  fi

  if [ -n "$filename" ]; then
    filename="$(sanitize_provider_name "$filename")"
  fi

  gdrive_verify_not_html "$direct_url" "$cookie_header" "$file_id"
  append_download "$direct_url" "$filename" "$cookie_header" "$origin" "gdrive"
  if [ -z "$filename" ]; then
    note "Google Drive: resolved file ID ${file_id}"
  else
    note "Google Drive: resolved file ID ${file_id} -> ${filename}"
  fi
}

gdrive_folder_entries_from_html() {
  python3 -c '
import ast
import json
import re
import sys

html = sys.stdin.read()
q = chr(39)
pattern = (
    r"window\[" + q + r"_DRIVE_ivd" + q + r"\]\s*=\s*" + q
    + r"((?:\\.|[^" + q + r"])*)"
    + q
)
match = re.search(pattern, html)
if not match:
    raise SystemExit(1)

try:
    raw = match.group(1).replace("\\/", "/")
    decoded = ast.literal_eval(q + raw + q)
    data = json.loads(decoded)
except Exception:
    raise SystemExit(1)

items = data[0] if isinstance(data, list) and data and isinstance(data[0], list) else []
for item in items:
    if not isinstance(item, list) or len(item) < 4:
        continue
    file_id = item[0]
    name = item[2]
    mime = item[3]
    if not isinstance(file_id, str) or not file_id:
        continue
    if not isinstance(name, str) or not name:
        continue
    if isinstance(mime, str) and mime.startswith("application/vnd.google-apps."):
        continue
    name = name.replace("\t", " ").replace("\r", " ").replace("\n", " ")
    sys.stdout.write("{}\t{}\n".format(file_id, name))
'
}

resolve_gdrive_folder() {
  local url="$1"
  local folder_id="$2"
  local folder_url html rows tab row_file_id row_filename output_name before added

  need_tool python3 "Install it with: brew install python"

  folder_url="https://drive.google.com/drive/folders/${folder_id}"
  note "Google Drive: resolving folder ${folder_id}"
  if ! html="$(curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$folder_url")"; then
    die "Google Drive folder request failed"
  fi

  rows="$(printf '%s' "$html" | gdrive_folder_entries_from_html || true)"
  [ -n "$rows" ] || die "No downloadable files found in Google Drive folder. The folder may be private, empty, or Google changed the public page format."

  before="${#DL_URLS[@]}"
  tab="$(printf '\t')"
  while IFS="$tab" read -r row_file_id row_filename; do
    [ -n "$row_file_id" ] || continue

    output_name=""
    if [ -n "$row_filename" ]; then
      output_name="$(sanitize_provider_name "$row_filename")"
    fi
    append_gdrive_file "$url" "$row_file_id" "$output_name"
  done <<EOF
$rows
EOF

  added=$((${#DL_URLS[@]} - before))
  [ "$added" -gt 0 ] || die "No downloadable files found in Google Drive folder"
  note "Google Drive: ${added} file(s) resolved from folder ${folder_id}"
}

resolve_gdrive() {
  local url="$1"
  local path file_id folder_id

  need_tool curl "macOS normally includes curl."

  path="$(url_path "$url")"
  case "$path" in
    */folders/*)
      folder_id="${path#*/folders/}"
      folder_id="${folder_id%%/*}"
      [ -n "$folder_id" ] || die "Could not extract Google Drive folder ID from: ${url}"
      resolve_gdrive_folder "$url" "$folder_id"
      return 0
      ;;
    /folderview)
      folder_id="$(query_param "$url" "id" || true)"
      [ -n "$folder_id" ] || die "Could not extract Google Drive folder ID from: ${url}"
      resolve_gdrive_folder "$url" "$folder_id"
      return 0
      ;;
    */file/d/*)
      file_id="${path#*/file/d/}"
      file_id="${file_id%%/*}"
      ;;
    *)
      file_id="$(query_param "$url" "id" || true)"
      ;;
  esac

  [ -n "$file_id" ] || die "Could not extract Google Drive file ID from: ${url}"

  append_gdrive_file "$url" "$file_id"
}

seyarabata_filename_from_html() {
  awk '
    BEGIN { RS = "</p>"; ORS = "" }
    /s-preview__title/ {
      gsub(/\n/, " ")
      sub(/.*s-preview__title[^>]*>/, "")
      gsub(/<[^>]*>/, "")
      gsub(/^[[:space:]]+/, "")
      gsub(/[[:space:]]+$/, "")
      print
      exit
    }
  '
}

resolve_seyarabata() {
  local url="$1"
  local path file_id preview_url html href download_url filename headers location loc_path

  need_tool curl "macOS normally includes curl."

  path="$(url_path "$url")"
  path="${path#/}"
  case "$path" in
    t/*|d/*)
      file_id="${path#*/}"
      file_id="${file_id%%/*}"
      ;;
    *)
      file_id="${path%%/*}"
      ;;
  esac

  [ -n "$file_id" ] || die "Could not extract Seyarabata file ID from: ${url}"

  preview_url="https://seyarabata.com/t/${file_id}"
  note "Seyarabata: resolving file ${file_id}"

  if ! html="$(curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$preview_url")"; then
    die "Seyarabata preview request failed"
  fi

  filename="$(printf '%s' "$html" | seyarabata_filename_from_html || true)"
  if [ -n "$filename" ]; then
    filename="$(html_decode_if_possible "$filename")"
    filename="$(sanitize_provider_name "$filename")"
  fi

  href="$(printf '%s' "$html" | sed -n 's/.*href="\([^"]*\/d\/[^"]*\)".*/\1/p' | head -n 1)"
  if [ -z "$href" ]; then
    href="/d/${file_id}"
  fi

  case "$href" in
    http://*|https://*) download_url="$href" ;;
    /*) download_url="https://seyarabata.com${href}" ;;
    *) download_url="https://seyarabata.com/${href}" ;;
  esac

  if [ -z "$filename" ]; then
    headers="$(curl -fsSI -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$download_url" 2>/dev/null || true)"
    location="$(printf '%s\n' "$headers" | tr -d '\r' | awk 'tolower($1) == "location:" {print $2; exit}')"
    if [ -n "$location" ]; then
      loc_path="$(url_path "$location")"
      filename="${loc_path##*/}"
      filename="$(url_decode_if_possible "$filename")"
      if [ -n "$filename" ]; then
        filename="$(sanitize_provider_name "$filename")"
      fi
    fi
  fi

  append_download "$download_url" "$filename" "" "$url" "seyarabata"
  if [ -n "$filename" ]; then
    note "Seyarabata: resolved ${filename}"
  else
    note "Seyarabata: resolved download endpoint"
  fi
}

resolve_transferit() {
  local url="$1"
  local path xh api_base info_payload info_json api_error info pw_required password_token
  local validate_payload validate_json validate_result api_query title_token filename files_count
  local zip_node node node_kind file_payload file_json g_payload g_json g_base encoded_filename
  local download_url

  need_tool curl "macOS normally includes curl."
  need_tool jq "Install it with: brew install jq"

  path="$(url_path "$url")"
  path="${path#/}"
  case "$path" in
    t/*)
      xh="${path#t/}"
      xh="${xh%%/*}"
      ;;
    *)
      die "Invalid Transfer.it URL. Expected transfer.it/t/<id>"
      ;;
  esac

  [ -n "$xh" ] || die "Could not extract Transfer.it transfer ID from: ${url}"

  api_base="${FASTGET_TRANSFERIT_API:-https://bt7.api.mega.co.nz}"
  api_base="${api_base%/}"
  note "Transfer.it: resolving transfer ${xh}"

  info_payload="$(jq -cn --arg xh "$xh" '[{a:"xi", xh:$xh}]')"
  if ! info_json="$(curl_json \
      -H "Content-Type: application/json" \
      --data "$info_payload" \
      "${api_base}/cs?id=0")"; then
    die "Transfer.it metadata request failed"
  fi

  api_error="$(printf '%s' "$info_json" | transferit_api_error)"
  [ -z "$api_error" ] || die "Transfer.it metadata API returned error ${api_error}"

  info="$(printf '%s' "$info_json" | jq -c 'if type == "array" then .[0] else . end')"
  [ "$(printf '%s' "$info" | jq -r 'type')" = "object" ] || die "Transfer.it metadata response was not an object"

  pw_required="$(json_value "$info" '.pw // false')"
  password_token=""
  if [ "$pw_required" = "true" ] || [ "$pw_required" = "1" ]; then
    [ -n "$PASSWORD" ] || die "Transfer.it link requires a password. Use -p password."
    password_token="$(transferit_password_token "$xh" "$PASSWORD")"

    validate_payload="$(jq -cn \
      --arg xh "$xh" \
      --arg pw "$password_token" \
      '[{a:"xv", xh:$xh, pw:$pw}]')"
    if ! validate_json="$(curl_json \
        -H "Content-Type: application/json" \
        --data "$validate_payload" \
        "${api_base}/cs?id=0")"; then
      die "Transfer.it password validation request failed"
    fi

    api_error="$(printf '%s' "$validate_json" | transferit_api_error)"
    [ -z "$api_error" ] || die "Transfer.it password validation returned error ${api_error}"

    validate_result="$(printf '%s' "$validate_json" | jq -r 'if type == "array" then .[0] else . end')"
    [ "$validate_result" = "1" ] || die "Invalid Transfer.it password"
  fi

  title_token="$(json_value "$info" '.t // empty')"
  filename=""
  if [ -n "$title_token" ] && [ "$title_token" != "null" ]; then
    filename="$(base64url_decode_if_possible "$title_token")"
    filename="$(sanitize_provider_name "$filename")"
  fi

  files_count="$(json_value "$info" '.size[1] // 0')"
  is_uint "$files_count" || files_count=0
  zip_node="$(json_value "$info" '.z // empty')"
  node=""
  node_kind="file"

  if [ "$files_count" -ne 1 ] && [ -n "$zip_node" ] && [ "$zip_node" != "null" ]; then
    node="$zip_node"
    node_kind="zip"
    if [ -z "$filename" ]; then
      filename="${xh}-${node}.zip"
    else
      case "$(lower "$filename")" in
        *.zip) ;;
        *) filename="${filename}.zip" ;;
      esac
    fi
  elif [ "$files_count" -gt 1 ]; then
    die "Transfer.it multi-file transfer did not include a downloadable archive node"
  else
    api_query="x=${xh}"
    if [ -n "$password_token" ]; then
      api_query="${api_query}&pw=${password_token}"
    fi

    file_payload='[{"a":"f","c":1,"r":1}]'
    if ! file_json="$(curl_json \
        -H "Content-Type: application/json" \
        --data "$file_payload" \
        "${api_base}/cs?id=0&${api_query}")"; then
      die "Transfer.it file-list request failed"
    fi

    api_error="$(printf '%s' "$file_json" | transferit_api_error)"
    [ -z "$api_error" ] || die "Transfer.it file-list API returned error ${api_error}"

    node="$(printf '%s' "$file_json" | jq -r '
      ((if type == "array" then .[0].f else .f end) // [])
      | map(select((.t // 1) == 0 and ((.h // "") != "")))
      | .[0].h // empty
    ')"
    [ -n "$node" ] || die "No downloadable file node found in Transfer.it link"

    if [ -z "$filename" ]; then
      filename="${xh}-${node}.bin"
    fi
  fi

  g_payload="$(jq -cn --arg n "$node" '[{a:"g", n:$n, pt:1, g:1, ssl:1}]')"
  api_query="x=${xh}"
  if [ -n "$password_token" ]; then
    api_query="${api_query}&pw=${password_token}"
  fi

  if ! g_json="$(curl_json \
      -H "Content-Type: application/json" \
      --data "$g_payload" \
      "${api_base}/cs?id=0&${api_query}")"; then
    die "Transfer.it download URL request failed"
  fi

  api_error="$(printf '%s' "$g_json" | transferit_api_error)"
  [ -z "$api_error" ] || die "Transfer.it download URL API returned error ${api_error}"

  g_base="$(printf '%s' "$g_json" | jq -r 'if type == "array" then .[0].g // empty else .g // empty end')"
  [ -n "$g_base" ] && [ "$g_base" != "null" ] || die "Transfer.it response did not include a downloadable URL"

  encoded_filename="$(url_encode_if_possible "$filename")"
  download_url="${g_base%/}/${encoded_filename}"

  append_download "$download_url" "$filename" "" "$url" "transferit"
  if [ "$node_kind" = "zip" ]; then
    note "Transfer.it: resolved transfer archive ${filename}"
  else
    note "Transfer.it: resolved ${filename}"
  fi
}

resolve_yandexdisk() {
  local url="$1"
  local api_base encoded_url metadata_url download_url metadata_json download_json
  local api_error api_message resource_type filename href

  need_tool curl "macOS normally includes curl."
  need_tool jq "Install it with: brew install jq"

  api_base="${FASTGET_YANDEXDISK_API:-https://cloud-api.yandex.net/v1/disk/public/resources}"
  api_base="${api_base%/}"
  encoded_url="$(jq -nr --arg url "$url" '$url | @uri')"
  metadata_url="${api_base}?public_key=${encoded_url}&limit=1"
  download_url="${api_base}/download?public_key=${encoded_url}"

  note "Yandex Disk: resolving public resource"
  if ! metadata_json="$(curl_json "$metadata_url")"; then
    die "Yandex Disk metadata request failed"
  fi

  api_error="$(json_value "$metadata_json" '.error // empty')"
  if [ -n "$api_error" ] && [ "$api_error" != "null" ]; then
    api_message="$(json_value "$metadata_json" '.message // .description // "unknown error"')"
    die "Yandex Disk metadata API error: ${api_message}"
  fi

  resource_type="$(json_value "$metadata_json" '.type // empty')"
  filename="$(json_value "$metadata_json" '.name // empty')"
  if [ -n "$filename" ] && [ "$filename" != "null" ]; then
    filename="$(sanitize_provider_name "$filename")"
    if [ "$resource_type" = "dir" ]; then
      case "$(lower "$filename")" in
        *.zip) ;;
        *) filename="${filename}.zip" ;;
      esac
    fi
  else
    filename=""
  fi

  if ! download_json="$(curl_json "$download_url")"; then
    die "Yandex Disk download URL request failed"
  fi

  api_error="$(json_value "$download_json" '.error // empty')"
  if [ -n "$api_error" ] && [ "$api_error" != "null" ]; then
    api_message="$(json_value "$download_json" '.message // .description // "unknown error"')"
    die "Yandex Disk download API error: ${api_message}"
  fi

  href="$(json_value "$download_json" '.href // empty')"
  [ -n "$href" ] && [ "$href" != "null" ] || die "Yandex Disk response did not include a download URL"

  append_download "$href" "$filename" "" "$url" "yandexdisk"
  if [ -n "$filename" ]; then
    note "Yandex Disk: resolved ${filename}"
  else
    note "Yandex Disk: resolved download endpoint"
  fi
}

resolve_mediafire_file_page() {
  local url="$1"
  local file_id="$2"
  local output_name="${3-}"
  local origin="${4-$url}"
  local html direct_url filename direct_path

  need_tool curl "macOS normally includes curl."

  note "MediaFire: resolving file ${file_id}"
  if ! html="$(curl -fsSL -A "${FASTGET_USER_AGENT:-Mozilla/5.0}" "$url")"; then
    die "MediaFire page request failed"
  fi

  direct_url="$(printf '%s' "$html" | mediafire_direct_from_html || true)"
  if [ -n "$direct_url" ]; then
    direct_url="$(html_decode_if_possible "$direct_url")"
  fi

  case "$direct_url" in
    http://*|https://*) ;;
    *) die "Could not find MediaFire direct download URL in page" ;;
  esac

  filename="$output_name"
  if [ -z "$filename" ]; then
    filename="$(printf '%s' "$html" | mediafire_filename_from_html || true)"
  fi

  if [ -n "$filename" ]; then
    filename="$(html_decode_if_possible "$filename")"
    filename="$(sanitize_provider_name "$filename")"
  else
    direct_path="$(url_path "$direct_url")"
    filename="${direct_path##*/}"
    filename="$(url_decode_if_possible "$filename")"
    if [ -n "$filename" ]; then
      filename="$(sanitize_provider_name "$filename")"
    fi
  fi

  append_download "$direct_url" "$filename" "" "$origin" "mediafire"
  if [ -n "$filename" ]; then
    note "MediaFire: resolved ${filename}"
  else
    note "MediaFire: resolved download endpoint"
  fi
}

mediafire_resolve_folder_files() {
  local origin="$1"
  local folder_key="$2"
  local prefix="${3-}"
  local chunk json rows more file_url filename output_name _quickkey

  chunk=1
  while :; do
    if ! json="$(mediafire_folder_content_json "$folder_key" "files" "$chunk")"; then
      die "MediaFire folder file-list request failed"
    fi
    mediafire_check_api_response "$json" "folder file-list"

    rows="$(printf '%s' "$json" | jq -r '
      .response.folder_content.files[]?
      | [(.links.normal_download // ""), (.filename // "file.bin"), (.quickkey // "")]
      | @tsv
    ')"

    while IFS="$(printf '\t')" read -r file_url filename _quickkey; do
      [ -n "$file_url" ] || continue
      filename="$(sanitize_provider_name "$filename")"
      if [ -n "$prefix" ]; then
        output_name="$(sanitize_provider_name "${prefix}_${filename}")"
      else
        output_name="$filename"
      fi
      resolve_mediafire_file_page "$file_url" "${_quickkey:-unknown}" "$output_name" "$origin"
    done <<EOF_ROWS
${rows}
EOF_ROWS

    more="$(json_value "$json" '.response.folder_content.more_chunks // "no"')"
    [ "$more" = "yes" ] || break
    chunk=$((chunk + 1))
  done
}

mediafire_resolve_folder_children() {
  local origin="$1"
  local folder_key="$2"
  local prefix="${3-}"
  local chunk json rows more child_key child_name child_prefix

  chunk=1
  while :; do
    if ! json="$(mediafire_folder_content_json "$folder_key" "folders" "$chunk")"; then
      die "MediaFire folder subfolder-list request failed"
    fi
    mediafire_check_api_response "$json" "folder subfolder-list"

    rows="$(printf '%s' "$json" | jq -r '
      .response.folder_content.folders[]?
      | [(.folderkey // .folder_key // .quickkey // ""), (.name // .foldername // .filename // "folder")]
      | @tsv
    ')"

    while IFS="$(printf '\t')" read -r child_key child_name; do
      [ -n "$child_key" ] || continue
      child_name="$(sanitize_provider_name "$child_name")"
      if [ -n "$prefix" ]; then
        child_prefix="$(sanitize_provider_name "${prefix}_${child_name}")"
      else
        child_prefix="$child_name"
      fi
      mediafire_resolve_folder_tree "$origin" "$child_key" "$child_prefix"
    done <<EOF_ROWS
${rows}
EOF_ROWS

    more="$(json_value "$json" '.response.folder_content.more_chunks // "no"')"
    [ "$more" = "yes" ] || break
    chunk=$((chunk + 1))
  done
}

mediafire_resolve_folder_tree() {
  local origin="$1"
  local folder_key="$2"
  local prefix="${3-}"

  mediafire_resolve_folder_files "$origin" "$folder_key" "$prefix"
  mediafire_resolve_folder_children "$origin" "$folder_key" "$prefix"
}

resolve_mediafire_folder() {
  local url="$1"
  local folder_key="$2"
  local before added

  need_tool jq "Install it with: brew install jq"

  note "MediaFire: resolving folder ${folder_key}"
  before="${#DL_URLS[@]}"
  mediafire_resolve_folder_tree "$url" "$folder_key" ""
  added=$((${#DL_URLS[@]} - before))
  [ "$added" -gt 0 ] || die "No downloadable files found in MediaFire folder"
  note "MediaFire: ${added} file(s) resolved from folder"
}

resolve_mediafire() {
  local url="$1"
  local path file_id folder_key

  path="$(url_path "$url")"
  case "$path" in
    /file/*|/download/*)
      file_id="${path#/file/}"
      file_id="${file_id#/download/}"
      file_id="${file_id%%/*}"
      [ -n "$file_id" ] || die "Could not extract MediaFire file ID from: ${url}"
      resolve_mediafire_file_page "$url" "$file_id"
      ;;
    /folder/*)
      folder_key="${path#/folder/}"
      folder_key="${folder_key%%/*}"
      [ -n "$folder_key" ] || die "Could not extract MediaFire folder key from: ${url}"
      resolve_mediafire_folder "$url" "$folder_key"
      ;;
    *)
      die "Invalid MediaFire URL. Expected mediafire.com/file/<id>/<name>/file or mediafire.com/folder/<key>/<name>"
      ;;
  esac
}

resolve_gofile() {
  local url="$1"
  local path content_id account_json account_status account_token
  local content_url password_hash content_json content_status before added
  local static_token link name

  need_tool curl "macOS normally includes curl."
  need_tool jq "Install it with: brew install jq"
  need_tool shasum "macOS normally includes shasum."

  path="$(url_path "$url")"
  path="${path#/}"
  case "$path" in
    d/*)
      content_id="${path#d/}"
      content_id="${content_id%%/*}"
      ;;
    *)
      content_id="${path%%/*}"
      ;;
  esac

  [ -n "$content_id" ] || die "Invalid Gofile URL. Expected gofile.io/d/<contentId>"

  note "Gofile: creating guest account"
  if ! account_json="$(curl_json -X POST "https://api.gofile.io/accounts")"; then
    die "Gofile account creation failed"
  fi

  account_status="$(json_value "$account_json" '.status // empty')"
  [ "$account_status" = "ok" ] || die "Gofile account error: ${account_status:-unknown}"

  account_token="$(json_value "$account_json" '.data.token // empty')"
  [ -n "$account_token" ] && [ "$account_token" != "null" ] || die "Failed to get Gofile account token"

  static_token="${FASTGET_GOFILE_WEBSITE_TOKEN:-4fd6sg89d7s6}"
  content_url="https://api.gofile.io/contents/${content_id}"
  if [ -n "$PASSWORD" ]; then
    password_hash="$(sha256_hex "$PASSWORD")"
    content_url="${content_url}?password=${password_hash}"
  fi

  note "Gofile: resolving content ${content_id}"
  if ! content_json="$(curl_json \
      -H "Authorization: Bearer ${account_token}" \
      -H "X-Website-Token: ${static_token}" \
      "$content_url")"; then
    die "Gofile content request failed"
  fi

  content_status="$(json_value "$content_json" '.status // empty')"
  case "$content_status" in
    ok) ;;
    error-passwordRequired) die "Gofile link requires a password. Use -p password." ;;
    error-notFound) die "Gofile content not found. Check the URL or it may have expired." ;;
    *) die "Gofile content error: ${content_status:-unknown}" ;;
  esac

  before="${#DL_URLS[@]}"
  while IFS="$(printf '\t')" read -r link name; do
    [ -n "$link" ] || continue
    name="$(sanitize_provider_name "$name")"
    append_download "$link" "$name" "accountToken=${account_token}" "$url" "gofile"
  done < <(printf '%s' "$content_json" | jq -r '
    def files:
      if (.type // "") == "file" and ((.link // "") != "") then
        [(.link // ""), (.name // "file.bin")] | @tsv
      elif ((.children? // {}) | type) == "object" then
        .children[] | files
      else
        empty
      end;
    .data | files
  ')

  added=$((${#DL_URLS[@]} - before))
  [ "$added" -gt 0 ] || die "No downloadable files found in Gofile link"
  note "Gofile: ${added} file(s) resolved"
}

resolve_swisstransfer() {
  local url="$1"
  local path folder_id api_base data expired credits container_uuid download_host
  local need_password rows before added encoded_password file_uuid filename token payload token_json file_url

  need_tool curl "macOS normally includes curl."
  need_tool jq "Install it with: brew install jq"
  need_tool base64 "macOS normally includes base64."

  path="$(url_path "$url")"
  path="${path%/}"
  folder_id="${path##*/}"
  [ -n "$folder_id" ] && [ "$folder_id" != "/" ] || die "Could not extract SwissTransfer folder ID from: ${url}"

  api_base="https://www.swisstransfer.com/api"
  note "SwissTransfer: resolving link ${folder_id}"

  if ! data="$(curl_json -H "Content-Type: application/json" "${api_base}/links/${folder_id}")"; then
    die "SwissTransfer API request failed"
  fi

  expired="$(json_value "$data" '.isExpired // false')"
  [ "$expired" != "true" ] || die "SwissTransfer link has expired"

  credits="$(json_value "$data" '.downloadCounterCredit // 1')"
  if [ "$credits" != "null" ] && [ "$credits" -le 0 ] 2>/dev/null; then
    die "SwissTransfer download limit reached"
  fi

  container_uuid="$(json_value "$data" '.UUID // empty')"
  download_host="$(json_value "$data" '.downloadHost // empty')"
  need_password="$(json_value "$data" '.needPassword // false')"

  [ -n "$container_uuid" ] && [ "$container_uuid" != "null" ] || die "SwissTransfer response is missing container UUID"
  [ -n "$download_host" ] && [ "$download_host" != "null" ] || die "SwissTransfer response is missing download host"
  download_host="${download_host%/}"

  if [ "$need_password" = "true" ] && [ -z "$PASSWORD" ]; then
    die "SwissTransfer link requires a password. Use -p password."
  fi

  rows="$(printf '%s' "$data" | jq -r '.container.files[]? | [(.UUID // ""), (.fileName // "file.bin")] | @tsv')"
  [ -n "$rows" ] || die "No files found in SwissTransfer link"

  encoded_password=""
  if [ "$need_password" = "true" ]; then
    encoded_password="$(printf '%s' "$PASSWORD" | base64 | tr -d '\n')"
  fi

  before="${#DL_URLS[@]}"
  while IFS="$(printf '\t')" read -r file_uuid filename; do
    [ -n "$file_uuid" ] || continue
    token=""
    if [ "$need_password" = "true" ]; then
      payload="$(jq -n \
        --arg containerUUID "$container_uuid" \
        --arg fileUUID "$file_uuid" \
        --arg password "$encoded_password" \
        '{containerUUID: $containerUUID, fileUUID: $fileUUID, password: $password}')"
      if ! token_json="$(curl_json \
          -X POST \
          -H "Content-Type: application/json" \
          --data "$payload" \
          "${api_base}/generateDownloadToken")"; then
        die "SwissTransfer token generation failed"
      fi
      token="$(json_value "$token_json" '.token // empty')"
      [ -n "$token" ] && [ "$token" != "null" ] || die "Invalid SwissTransfer password or empty download token"
    fi

    filename="$(sanitize_provider_name "$filename")"
    file_url="${download_host}/api/download/${folder_id}/${file_uuid}"
    if [ -n "$token" ]; then
      file_url="${file_url}?token=${token}"
    fi
    append_download "$file_url" "$filename" "" "$url" "swisstransfer"
  done <<EOF_ROWS
${rows}
EOF_ROWS

  added=$((${#DL_URLS[@]} - before))
  [ "$added" -gt 0 ] || die "No downloadable files found in SwissTransfer link"
  note "SwissTransfer: ${added} file(s) resolved"
}

resolve_input() {
  local item="$1"

  if is_pixeldrain "$item"; then
    resolve_pixeldrain "$item"
  elif is_gofile "$item"; then
    resolve_gofile "$item"
  elif is_swisstransfer "$item"; then
    resolve_swisstransfer "$item"
  elif is_gdrive "$item"; then
    resolve_gdrive "$item"
  elif is_seyarabata "$item"; then
    resolve_seyarabata "$item"
  elif is_transferit "$item"; then
    resolve_transferit "$item"
  elif is_yandexdisk "$item"; then
    resolve_yandexdisk "$item"
  elif is_mediafire "$item"; then
    resolve_mediafire "$item"
  else
    if is_torrent_like "$item" && ! has_uri_scheme "$item"; then
      case "$(lower "$item")" in
        magnet:*) ;;
        *) [ -f "$item" ] || die "Torrent file not found: ${item}" ;;
      esac
    fi
    append_download "$item" "" "" "$item" "direct"
  fi
}

detect_conn_cap() {
  local cap
  cap="$(aria2c -h 2>/dev/null | awk '
    /--max-connection-per-server=NUM/ {seen=1; next}
    seen && /Possible Values:/ {gsub(/[^0-9-]/,""); split($0,a,"-"); print a[2]; exit}
  ')"
  case "$cap" in
    ''|*[!0-9]*) echo 16 ;;
    *) echo "$cap" ;;
  esac
}

has_opt() {
  case "$ARIA_HELP" in
    *"$1"*) return 0 ;;
    *) return 1 ;;
  esac
}

download_one() {
  local url="$1"
  local output_name="$2"
  local cookie="$3"
  local provider="$4"
  local opts

  opts=("${COMMON_OPTS[@]}")

  if is_torrent_like "$url"; then
    opts+=("${TORRENT_OPTS[@]}")
    if [ -n "$OUT_NAME" ]; then
      note "-o is ignored for torrent and magnet downloads; torrent metadata controls output paths"
    fi
  else
    opts+=("${HTTP_OPTS[@]}")
    if [ -n "$output_name" ]; then
      opts+=( -o "$output_name" )
    fi
  fi

  if [ -n "$cookie" ]; then
    opts+=( --header="Cookie: ${cookie}" )
  fi

  case "$provider" in
    direct) echo "Downloading: ${url}" >&2 ;;
    *) echo "Downloading ${provider} file${output_name:+: ${output_name}}" >&2 ;;
  esac

  aria2c "${opts[@]}" "$url"
}

batch_add_http() {
  local i="${#BATCH_URLS[@]}"
  BATCH_URLS[i]="$1"
  BATCH_NAMES[i]="$2"
  BATCH_COOKIES[i]="$3"
  BATCH_PROVIDERS[i]="$4"
}

reset_http_batch() {
  BATCH_URLS=()
  BATCH_NAMES=()
  BATCH_COOKIES=()
  BATCH_PROVIDERS=()
}

download_http_batch() {
  local count="$1"
  local input_file rc idx url name cookie provider
  local opts

  if [ "$count" -eq 0 ]; then
    return 0
  fi

  if [ "$count" -eq 1 ] || [ "$FASTGET_PARALLEL" -le 1 ]; then
    idx=0
    while [ "$idx" -lt "$count" ]; do
      download_one "${BATCH_URLS[$idx]}" "${BATCH_NAMES[$idx]}" "${BATCH_COOKIES[$idx]}" "${BATCH_PROVIDERS[$idx]}"
      idx=$((idx + 1))
    done
    return 0
  fi

  input_file="$(mktemp "${TMPDIR:-/tmp}/fastget.XXXXXX")" || die "Could not create temporary aria2 input file"
  idx=0
  while [ "$idx" -lt "$count" ]; do
    url="${BATCH_URLS[$idx]}"
    name="${BATCH_NAMES[$idx]}"
    cookie="${BATCH_COOKIES[$idx]}"
    {
      printf '%s\n' "$url"
      if [ -n "$name" ]; then
        printf '  out=%s\n' "$name"
      fi
      if [ -n "$cookie" ]; then
        printf '  header=Cookie: %s\n' "$cookie"
      fi
    } >>"$input_file"
    idx=$((idx + 1))
  done

  opts=("${COMMON_OPTS[@]}" "${HTTP_OPTS[@]}" --max-concurrent-downloads="${FASTGET_PARALLEL}")
  has_opt "--deferred-input" && opts+=( --deferred-input=true )

  echo "Downloading ${count} HTTP files with up to ${FASTGET_PARALLEL} parallel jobs" >&2
  set +e
  aria2c "${opts[@]}" --input-file="$input_file"
  rc=$?
  set -e
  rm -f "$input_file"
  return "$rc"
}

flush_http_batch() {
  local count="${#BATCH_URLS[@]}"
  download_http_batch "$count"
  reset_http_batch
}

