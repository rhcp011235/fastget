#!/usr/bin/env bash
# fastget - universal aria2c wrapper with host resolvers.
# Supports direct URLs, Pixeldrain, Gofile, SwissTransfer, Google Drive,
# Seyarabata, Transfer.it, Yandex Disk, MediaFire, magnet links, and
# local/remote .torrent files.

set -euo pipefail

PROGRAM="${0##*/}"
PROFILE="aggressive"
OUT_NAME=""
PASSWORD="${FASTGET_PASSWORD:-}"
FASTGET_INTERFACE="${FASTGET_INTERFACE:-}"
FASTGET_PARALLEL="${FASTGET_PARALLEL:-}"
GDRIVE_COOKIE_FROM_CLIPBOARD="${FASTGET_GDRIVE_COOKIE_FROM_CLIPBOARD:-}"
GDRIVE_COOKIE_FROM_CHROME="${FASTGET_GDRIVE_COOKIE_FROM_CHROME:-}"
FASTGET_GDRIVE_COOKIE_CACHE="${FASTGET_GDRIVE_COOKIE_CACHE:-${XDG_CONFIG_HOME:-$HOME/.config}/fastget/gdrive-cookie}"
FASTGET_GDRIVE_COOKIE_CACHE_DISABLE="${FASTGET_GDRIVE_COOKIE_CACHE_DISABLE:-}"
INPUTS=()

usage() {
  cat <<EOF
Usage:
  ${PROGRAM} [--sane] [-o output] [-p password] <url-or-torrent> [more...]

Examples:
  ${PROGRAM} https://example.com/file.zip
  ${PROGRAM} -o file.zip https://example.com/download
  ${PROGRAM} -p secret https://www.swisstransfer.com/d/<id>
  ${PROGRAM} https://transfer.it/t/<id>
  ${PROGRAM} https://disk.yandex.com.tr/d/<id>
  ${PROGRAM} https://drive.google.com/drive/folders/<id>
  ${PROGRAM} https://www.mediafire.com/file/<id>/<name>/file
  ${PROGRAM} https://www.mediafire.com/folder/<id>/<name>
  ${PROGRAM} --interface en9 https://example.com/huge.bin
  ${PROGRAM} --parallel 6 https://example.com/a.bin https://example.com/b.bin
  ${PROGRAM} "magnet:?xt=urn:btih:..."
  ${PROGRAM} ./file.torrent

Supported:
  direct HTTP(S), Pixeldrain, Gofile, SwissTransfer, Google Drive file/folder,
  Seyarabata, Transfer.it, Yandex Disk, MediaFire, magnet links, local .torrent
  files, and remote .torrent URLs.

Options:
  --sane                 Use a less aggressive aria2 profile.
  --aggressive           Use the default aggressive aria2 profile.
  -o, --output NAME      Output filename. Used only when one HTTP file resolves.
  -p, --password VALUE   Password for Gofile, SwissTransfer, or Transfer.it.
  --interface IFACE      Bind aria2 sockets to an interface, e.g. en9 for 10GbE.
  --parallel N           Parallel HTTP files after provider resolution.
  --gdrive-cookie-from-clipboard
                         Parse and cache Google Drive cookies from copied cURL.
  --gdrive-cookie-from-chrome
                         Read Google Drive cookies directly from Chrome (macOS).
  -h, --help             Show this help.

Environment:
  FASTGET_PASSWORD       Password fallback for protected hosts.
  FASTGET_INTERFACE      Optional aria2 socket binding interface.
  FASTGET_PARALLEL       Parallel HTTP file downloads, default 4 aggressive.
  FASTGET_GDRIVE_COOKIE  Raw Cookie header for Google Drive account downloads.
  FASTGET_GDRIVE_COOKIE_FILE
                         Netscape/curl cookie jar for Google Drive downloads.
  FASTGET_GDRIVE_COOKIE_FROM_CLIPBOARD
                         Set to 1 to parse/cache Google Drive cookies from clipboard.
  FASTGET_GDRIVE_COOKIE_FROM_CHROME
                         Set to 1 to read Google Drive cookies from Chrome (macOS).
  FASTGET_GDRIVE_CHROME_PROFILE
                         Chrome profile directory name (e.g. "Default", "Profile 1").
  FASTGET_GDRIVE_COOKIE_CACHE
                         Cookie cache path, default ~/.config/fastget/gdrive-cookie.
  FASTGET_GDRIVE_COOKIE_CACHE_DISABLE
                         Set to 1 to disable the Google Drive cookie cache.
  FASTGET_ULIMIT_NOFILE  Runtime file descriptor soft limit, default 8192.
  ARIA_CONN              Connections per server before aria2 cap clamping.
  ARIA_SPLIT             aria2 split count.
  ARIA_CHUNK             aria2 min split and piece size.
  ARIA_CACHE             aria2 disk cache size.
  ARIA_FILE_ALLOCATION   aria2 file allocation method, default trunc aggressive.
  ARIA_TRIES             aria2 max tries, default 0 (unlimited).
  ARIA_WAIT              aria2 retry wait seconds.
  ARIA_BT_TRACKERS       Comma-separated extra BitTorrent trackers.
  ARIA_BT_STOP_TIMEOUT   Stop torrent if speed is 0 for this many seconds.
  FASTGET_TRANSFERIT_API Transfer.it API base, default https://bt7.api.mega.co.nz.
  FASTGET_YANDEXDISK_API Yandex public resources API base.
  FASTGET_MEDIAFIRE_API  MediaFire API base, default https://www.mediafire.com/api/1.5.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

note() {
  echo "Note: $*" >&2
}

need_tool() {
  local tool="$1"
  local hint="${2-}"
  if ! command -v "$tool" >/dev/null 2>&1; then
    if [ -n "$hint" ]; then
      die "Missing required tool: ${tool}. ${hint}"
    fi
    die "Missing required tool: ${tool}"
  fi
}

is_uint() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

raise_fd_limit() {
  local requested current
  requested="${FASTGET_ULIMIT_NOFILE:-8192}"

  is_uint "$requested" || die "FASTGET_ULIMIT_NOFILE must be a number"
  [ "$requested" -gt 0 ] || return 0

  current="$(ulimit -n)"
  if [ "$current" = "unlimited" ]; then
    return 0
  fi

  if is_uint "$current" && [ "$current" -lt "$requested" ]; then
    if ! ulimit -n "$requested" 2>/dev/null; then
      note "could not raise file descriptor limit from ${current} to ${requested}"
    fi
  fi
}

lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

is_http() {
  case "$(lower "$1")" in
    http://*|https://*) return 0 ;;
    *) return 1 ;;
  esac
}

has_uri_scheme() {
  case "$(lower "$1")" in
    *://*|magnet:*) return 0 ;;
    *) return 1 ;;
  esac
}

url_host() {
  local url="$1"
  local rest host

  rest="${url#*://}"
  if [ "$rest" = "$url" ]; then
    printf ''
    return 0
  fi

  host="${rest%%/*}"
  host="${host%%\?*}"
  host="${host%%#*}"
  host="${host%%:*}"
  lower "$host"
}

url_path() {
  local url="$1"
  local rest path

  rest="${url#*://}"
  if [ "$rest" = "$url" ]; then
    rest="$url"
  fi

  case "$rest" in
    */*) path="/${rest#*/}" ;;
    *) path="/" ;;
  esac

  path="${path%%#*}"
  path="${path%%\?*}"
  printf '%s' "$path"
}

query_param() {
  local url="$1"
  local key="$2"
  local qs pair name value

  case "$url" in
    *\?*) qs="${url#*\?}" ;;
    *) return 1 ;;
  esac
  qs="${qs%%#*}"

  while [ -n "$qs" ]; do
    case "$qs" in
      *'&'*)
        pair="${qs%%&*}"
        qs="${qs#*&}"
        ;;
      *)
        pair="$qs"
        qs=""
        ;;
    esac

    name="${pair%%=*}"
    value="${pair#*=}"
    if [ "$name" = "$key" ]; then
      printf '%s' "$value"
      return 0
    fi
  done

  return 1
}

host_matches() {
  local host domain
  host="$(url_host "$1")"
  domain="$2"

  case "$host" in
    "$domain"|*."$domain") return 0 ;;
    *) return 1 ;;
  esac
}

is_pixeldrain() {
  host_matches "$1" "pixeldrain.com"
}

is_gofile() {
  host_matches "$1" "gofile.io"
}

is_swisstransfer() {
  host_matches "$1" "swisstransfer.com"
}

is_gdrive() {
  host_matches "$1" "drive.google.com" || host_matches "$1" "drive.usercontent.google.com"
}

is_seyarabata() {
  local host
  host="$(url_host "$1")"
  case "$host" in
    seyarabata.com|www.seyarabata.com) return 0 ;;
    *) return 1 ;;
  esac
}

is_transferit() {
  local host
  host="$(url_host "$1")"
  case "$host" in
    transfer.it|www.transfer.it) return 0 ;;
    *) return 1 ;;
  esac
}

is_yandexdisk() {
  local host
  host="$(url_host "$1")"
  case "$host" in
    yadi.sk|www.yadi.sk|disk.yandex.*) return 0 ;;
    *) return 1 ;;
  esac
}

is_mediafire() {
  local host
  host="$(url_host "$1")"
  case "$host" in
    mediafire.com|www.mediafire.com|m.mediafire.com) return 0 ;;
    *) return 1 ;;
  esac
}

is_password_provider() {
  is_gofile "$1" || is_swisstransfer "$1" || is_transferit "$1"
}

is_torrent_like() {
  local item="$1"
  local clean

  case "$(lower "$item")" in
    magnet:*) return 0 ;;
  esac

  clean="${item%%#*}"
  clean="${clean%%\?*}"
  case "$(lower "$clean")" in
    *.torrent) return 0 ;;
    *) return 1 ;;
  esac
}

looks_like_source() {
  local item="$1"

  if has_uri_scheme "$item" || is_torrent_like "$item"; then
    return 0
  fi
  [ -e "$item" ]
}

sanitize_provider_name() {
  local name="$1"
  name="$(printf '%s' "$name" | sed 's#[/]#_#g; s#[[:cntrl:]]#_#g')"
  if [ -z "$name" ]; then
    name="file.bin"
  fi
  printf '%s' "$name"
}

url_decode_if_possible() {
  local value="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import sys, urllib.parse; print(urllib.parse.unquote(sys.argv[1]))' "$value" 2>/dev/null || printf '%s' "$value"
  else
    printf '%s' "$value"
  fi
}

url_encode_if_possible() {
  local value="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$value" 2>/dev/null || printf '%s' "$value"
  else
    printf '%s' "$value"
  fi
}

base64url_decode_if_possible() {
  local value="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c '
import base64
import sys

value = sys.argv[1].strip()
value += "=" * (-len(value) % 4)
sys.stdout.write(base64.urlsafe_b64decode(value).decode("utf-8", "replace"))
' "$value" 2>/dev/null || printf '%s' "$value"
  else
    printf '%s' "$value"
  fi
}

html_decode_if_possible() {
  local value="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import html, sys; print(html.unescape(sys.argv[1]))' "$value" 2>/dev/null || printf '%s' "$value"
  else
    printf '%s' "$value"
  fi
}

mediafire_direct_from_html() {
  awk '
    BEGIN { RS = "<a"; ORS = "" }
    /id="downloadButton"/ || /aria-label="Download file"/ {
      if (match($0, /href="[^"]+"/)) {
        print substr($0, RSTART + 6, RLENGTH - 7)
        exit
      }
    }
  '
}

mediafire_filename_from_html() {
  awk '
    /var optFileName = "/ {
      sub(/.*var optFileName = "/, "")
      sub(/".*/, "")
      print
      exit
    }
  '
}

mediafire_check_api_response() {
  local json="$1"
  local context="$2"
  local result message

  result="$(json_value "$json" '.response.result // empty')"
  if [ "$result" != "Success" ]; then
    message="$(json_value "$json" '.response.message // .response.error // .response.error_message // "unknown error"')"
    die "MediaFire ${context} API error: ${message}"
  fi
}

mediafire_folder_content_json() {
  local folder_key="$1"
  local content_type="$2"
  local chunk="$3"
  local api_base encoded_key

  api_base="${FASTGET_MEDIAFIRE_API:-https://www.mediafire.com/api/1.5}"
  api_base="${api_base%/}"
  encoded_key="$(jq -nr --arg value "$folder_key" '$value | @uri')"
  curl_json "${api_base}/folder/get_content.php?folder_key=${encoded_key}&content_type=${content_type}&chunk=${chunk}&response_format=json"
}

curl_json() {
  curl -fsSL --connect-timeout "${FASTGET_CONNECT_TIMEOUT:-20}" --max-time "${FASTGET_API_TIMEOUT:-60}" "$@"
}

json_value() {
  local json="$1"
  local filter="$2"
  printf '%s' "$json" | jq -r "$filter"
}

sha256_hex() {
  printf '%s' "$1" | shasum -a 256 | awk '{print $1}'
}

transferit_password_token() {
  local xh="$1"
  local password="$2"

  need_tool python3 "Install it with: brew install python"
  python3 - "$xh" "$password" <<'PY'
import base64
import hashlib
import sys

xh = sys.argv[1]
password = sys.argv[2]


def b64url_decode(value):
    if isinstance(value, str):
        value = value.encode("ascii")
    value += b"=" * (-len(value) % 4)
    return base64.urlsafe_b64decode(value)


try:
    if len(xh) > 12:
        seed = b64url_decode(b64url_decode(xh))[-7:-1]
    else:
        seed = b64url_decode(xh)[-6:]
    salt = seed * 3
    digest = hashlib.pbkdf2_hmac(
        "sha256",
        password.strip().encode("utf-8"),
        salt,
        100000,
        32,
    )
    print(base64.urlsafe_b64encode(digest).decode("ascii").rstrip("="))
except Exception as exc:
    raise SystemExit(f"failed to derive Transfer.it password token: {exc}")
PY
}

